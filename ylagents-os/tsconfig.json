{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "lib": ["ESNext", "DOM"],
    "baseUrl": ".",
    "paths": {
      "@ylagents/core/*": ["packages/core/src/*"],
      "@ylagents/bridge/*": ["packages/bridge/src/*"],
      "@ylagents/providers/*": ["packages/providers/src/*"]
    }
  }
}
