{
  "name": "ylagents-os",
  "private": true,
  "version": "0.1.0",
  "description": "Local-first mobile AI agent OS",
  "workspaces": [
    "packages/ui",
    "packages/ui/packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "bun --cwd packages/ui dev",
    "build:ui": "bun --cwd packages/ui build",
    "mobile:ios": "bun --cwd apps/mobile-desktop ios",
    "mobile:android": "bun --cwd apps/mobile-desktop android"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
